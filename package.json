{
    "name": "nheengeta",
    "displayName": "Nheengetá Notebooks",
    "description": "Polyglot notebooks powered by the .NET Interactive kernel — C#, F#, T-SQL, KQL, PowerShell, JavaScript, Python, R, HTML and Mermaid, all speaking together.",
    "version": "0.1.20",
    "publisher": "HermesSilva",
    "license": "MIT",
    "icon": "media/icon.png",
    "homepage": "https://github.com/hermessilva/Nheengeta#readme",
    "bugs": {
        "url": "https://github.com/hermessilva/Nheengeta/issues"
    },
    "keywords": [
        "notebook",
        "polyglot",
        "dotnet-interactive",
        "csharp",
        "fsharp",
        "sql",
        "kql",
        "interactive"
    ],
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hermessilva/Nheengeta.git"
    },
    "engines": {
        "vscode": "^1.99.0"
    },
    "categories": [
        "Notebooks",
        "Data Science",
        "Programming Languages"
    ],
    "activationEvents": [
        "onNotebook:nheengeta",
        "onCommand:Nheengeta.New",
        "onCommand:Nheengeta.Open"
    ],
    "main": "./out/ExtensionMain.js",
    "contributes": {
        "configurationDefaults": {
            "notebook.cellToolbarLocation": {
                "nheengeta": "left"
            },
            "notebook.lineNumbers": "on",
            "notebook.showCellStatusBar": "hidden",
            "debug.allowBreakpointsEverywhere": true,
            "debug.inlineValues": "on"
        },
        "notebooks": [
            {
                "type": "nheengeta",
                "displayName": "Nheengetá Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.nhg"
                    }
                ]
            }
        ],
        "notebookRenderer": [
            {
                "id": "nheengeta-mermaid",
                "displayName": "Nheengetá Mermaid",
                "entrypoint": "./out/Renderer/MermaidRenderer.js",
                "mimeTypes": [
                    "text/vnd.mermaid"
                ]
            },
            {
                "id": "nheengeta-plot",
                "displayName": "Nheengetá Plot",
                "entrypoint": "./out/Renderer/PlotRenderer.js",
                "mimeTypes": [
                    "application/vnd.nheengeta.plot+json"
                ]
            },
            {
                "id": "nheengeta-math",
                "displayName": "Nheengetá Math (KaTeX)",
                "entrypoint": "./out/Renderer/MathRenderer.js",
                "mimeTypes": [
                    "application/vnd.nheengeta.math+json"
                ]
            }
        ],
        "languages": [
            {
                "id": "nheengeta",
                "extensions": [
                    ".nhg"
                ],
                "aliases": [
                    "Nheengetá"
                ]
            },
            {
                "id": "math",
                "aliases": [
                    "Math (Nheengetá)"
                ]
            }
        ],
        "commands": [
            {
                "command": "Nheengeta.New",
                "title": "New Nheengetá Notebook",
                "category": "Nheengetá",
                "icon": "$(notebook)"
            },
            {
                "command": "Nheengeta.Open",
                "title": "Open Nheengetá Notebook",
                "category": "Nheengetá",
                "icon": "$(folder-opened)"
            },
            {
                "command": "Nheengeta.RestartKernel",
                "title": "Restart Kernel",
                "category": "Nheengetá",
                "icon": "$(refresh)"
            },
            {
                "command": "Nheengeta.InstallKernel",
                "title": "Install .NET Interactive Kernel",
                "category": "Nheengetá",
                "icon": "$(cloud-download)"
            },
            {
                "command": "Nheengeta.CopyCellOutput",
                "title": "Copy Output — cell results to the clipboard",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/copy.svg",
                    "dark": "media/toolbar/copy.svg"
                }
            },
            {
                "command": "Nheengeta.SelectCellLanguage",
                "title": "Language — C#, F#, SQL, Python… (ladybug = debuggable)",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/language.svg",
                    "dark": "media/toolbar/language.svg"
                }
            },
            {
                "command": "Nheengeta.RunCell",
                "title": "Run Cell — execute only this cell",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/run.svg",
                    "dark": "media/toolbar/run.svg"
                }
            },
            {
                "command": "Nheengeta.RunToHere",
                "title": "Run to Here — execute every cell from the top to this one",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/runtohere.svg",
                    "dark": "media/toolbar/runtohere.svg"
                }
            },
            {
                "command": "Nheengeta.ExportCellOutput",
                "title": "Export Output — save cell results as .html/.txt",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/export.svg",
                    "dark": "media/toolbar/export.svg"
                }
            },
            {
                "command": "Nheengeta.DebugCell",
                "title": "Debug Cell — breakpoints, watch, step (JavaScript, Python, PowerShell)",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/ladybug.svg",
                    "dark": "media/toolbar/ladybug.svg"
                }
            },
            {
                "command": "Nheengeta.AddPackage",
                "title": "Add Package — #!use from nuget/npm/pip/PSGallery/CRAN",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/package.svg",
                    "dark": "media/toolbar/package.svg"
                }
            },
            {
                "command": "Nheengeta.RefreshVariables",
                "title": "Refresh Variables",
                "category": "Nheengetá",
                "icon": "$(refresh)"
            },
            {
                "command": "Nheengeta.EditVariable",
                "title": "Set Value",
                "category": "Nheengetá",
                "icon": "$(edit)"
            },
            {
                "command": "Nheengeta.AskAi",
                "title": "Ask AI — fix the error, explain or improve this cell",
                "category": "Nheengetá",
                "icon": {
                    "light": "media/toolbar/ai.svg",
                    "dark": "media/toolbar/ai.svg"
                }
            }
        ],
        "viewsContainers": {
            "panel": [
                {
                    "id": "nheengeta",
                    "title": "Nheengetá",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "nheengeta": [
                {
                    "id": "nheengetaVariables",
                    "name": "Variables",
                    "icon": "media/icon.svg",
                    "contextualTitle": "Nheengetá Variables"
                }
            ]
        },
        "menus": {
            "notebook/cell/title": [
                {
                    "command": "Nheengeta.RunCell",
                    "when": "notebookType == nheengeta",
                    "group": "inline@0"
                },
                {
                    "command": "Nheengeta.SelectCellLanguage",
                    "when": "notebookType == nheengeta",
                    "group": "inline@1"
                },
                {
                    "command": "Nheengeta.RunToHere",
                    "when": "notebookType == nheengeta",
                    "group": "inline@2"
                },
                {
                    "command": "Nheengeta.DebugCell",
                    "when": "notebookType == nheengeta",
                    "group": "inline@3"
                },
                {
                    "command": "Nheengeta.AskAi",
                    "when": "notebookType == nheengeta",
                    "group": "inline@4"
                },
                {
                    "command": "Nheengeta.AddPackage",
                    "when": "notebookType == nheengeta",
                    "group": "inline@5"
                },
                {
                    "command": "Nheengeta.CopyCellOutput",
                    "when": "notebookType == nheengeta",
                    "group": "inline@6"
                },
                {
                    "command": "Nheengeta.ExportCellOutput",
                    "when": "notebookType == nheengeta",
                    "group": "inline@7"
                }
            ],
            "notebook/toolbar": [
                {
                    "command": "Nheengeta.RestartKernel",
                    "when": "notebookType == nheengeta",
                    "group": "navigation@1"
                }
            ],
            "view/title": [
                {
                    "command": "Nheengeta.RefreshVariables",
                    "when": "view == nheengetaVariables",
                    "group": "navigation@1"
                }
            ],
            "view/item/context": [
                {
                    "command": "Nheengeta.EditVariable",
                    "when": "view == nheengetaVariables && viewItem == nheengeta-variable",
                    "group": "inline@1"
                }
            ]
        },
        "configuration": {
            "title": "Nheengetá",
            "properties": {
                "nheengeta.dotnetPath": {
                    "type": "string",
                    "default": "dotnet",
                    "description": "Path to the dotnet executable used to launch the .NET Interactive kernel."
                },
                "nheengeta.kernelArgs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Extra arguments passed to `dotnet interactive stdio`."
                },
                "nheengeta.handleIpynb": {
                    "type": "boolean",
                    "default": false,
                    "description": "Also open .ipynb files with the Nheengetá notebook editor (may conflict with Jupyter/Polyglot extensions)."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./ && npm run compile-renderer && npm run compile-plot && npm run compile-math && npm run compile-katex-css && npm run compile-math-renderer",
        "compile-renderer": "esbuild src/Renderer/MermaidRenderer.ts --bundle --format=esm --minify --outfile=out/Renderer/MermaidRenderer.js",
        "compile-plot": "esbuild src/Renderer/PlotRenderer.ts --bundle --format=esm --minify --outfile=out/Renderer/PlotRenderer.js",
        "compile-math": "esbuild src/Math/MathEngine.ts --bundle --format=cjs --platform=node --minify --outfile=out/Math/MathEngine.js",
        "compile-katex-css": "esbuild node_modules/katex/dist/katex.min.css --bundle --loader:.woff2=dataurl --loader:.woff=empty --loader:.ttf=empty --outfile=src/Renderer/generated/katex-inline.css",
        "compile-math-renderer": "esbuild src/Renderer/MathRenderer.ts --bundle --format=esm --minify --loader:.css=text --outfile=out/Renderer/MathRenderer.js",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "pack-lib": "npm pack"
    },
    "files": [
        "out/**",
        "media/**",
        "LICENSE",
        "README.md"
    ],
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/vscode": "^1.99.0",
        "@types/vscode-notebook-renderer": "^1.72.0",
        "esbuild": "^0.21.0",
        "katex": "^0.16.0",
        "mathjs": "^13.0.0",
        "mermaid": "^10.9.0",
        "plotly.js-dist-min": "^2.33.0",
        "typescript": "^5.3.0"
    }
}
